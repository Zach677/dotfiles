[user]
	name = Zach
	email = 2801818616z@gmail.com
	signingkey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDywDWZq31zxpDSDpVRXUWhnQbwi5LkBsxBUal302pG4
[alias]
	sa = status
	go = checkout
	br = branch
	ci = commit
	st = status
	ps = push
	pl = pull
	tree = log --graph --oneline --all
	s = status
	out = fire
	going = fire
[gpg]
	format = ssh
[gpg "ssh"]
	program = "/usr/bin/ssh-keygen"
	allowedSigners = /Users/star/.ssh/allowedSigners
[commit]
	gpgsign = true
[core]
    autocrlf = input
	ignorecase = false
	excludesfile = /Users/star/.gitignore
[mergetool]
	keepBackup = false

[push]
	default = simple
	autoSetupRemote = true
[pull]
	default = current
	rebase = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	ff = only
[init]
	defaultBranch = main
[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
[rebase]
    autoStash = true
[branch]
    autoSetupMerge = simple
